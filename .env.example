# Auth.js v5 세션 서명/암호화 키 — `npx auth secret`으로 생성
AUTH_SECRET=

# GitHub OAuth App (profile-admin 전용, 콜백: https://{도메인}/api/auth/callback/github)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# allowlist — 본인 GitHub 숫자 ID(profile.id). 사용자명(login)이 아님 — 변경 가능하므로 사용 금지
ALLOWED_GITHUB_ID=

# content-hub 쓰기용 fine-grained PAT (contents:write + pull-requests:write). 클라이언트 미노출, 서버 전용
GITHUB_PAT=
